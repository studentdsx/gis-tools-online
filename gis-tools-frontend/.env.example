# Mapbox GL（必填）：https://account.mapbox.com/access-tokens/
VITE_MAPBOX_ACCESS_TOKEN=

# 可选。留空则请求同源路径 /api/*（开发/预览时由 Vite 代理到后端）
# 生产环境前后端分离时设为后端根地址，例如 https://api.example.com
# VITE_API_BASE_URL=

# 可选。仅影响 vite dev / vite preview 的代理目标（默认 http://localhost:3000）
# VITE_DEV_API_PROXY=http://127.0.0.1:3000
