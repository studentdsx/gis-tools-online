# Frontend runtime configuration mounted by docker compose.
# Leave VITE_API_BASE_URL empty to call same-origin /api through Nginx.
# For separated deployment, set the backend API origin that browsers can reach.
# Example: VITE_API_BASE_URL=http://10.10.201.118:3000
VITE_API_BASE_URL=

# Optional Mapbox token. Raster basemaps can work without it.
VITE_MAPBOX_ACCESS_TOKEN=
