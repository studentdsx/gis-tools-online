# PostGIS initialization configuration.
# These values are used when the PostGIS volume is first created.
POSTGRES_DB=gis_tools
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Keep PostgreSQL and container timezone aligned with the deployment host.
# For Linux hosts, docker-compose.yml and deploy/run-postgis.sh also mount
# /etc/localtime and /etc/timezone from the host when available.
TZ=Asia/Shanghai
PGTZ=Asia/Shanghai
