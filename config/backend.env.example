# Backend runtime configuration mounted by docker compose.
PORT=3000
NODE_ENV=production

# Use a database address reachable from the backend container.
# Use DB_HOST=postgis only for the bundled PostGIS service in this compose file.
# For a database on the Docker host, try DB_HOST=host.docker.internal.
# For another server, use its intranet IP or DNS name.
DB_HOST=postgis
DB_PORT=5432
DB_NAME=gis_tools
DB_USER=postgres
DB_PASSWORD=postgres
